---
import type { MarkdownHeading } from 'astro';
import { FullWidthContainer } from '@chromatic-com/tetra';
import '@docsearch/css';
import SEO from '../components/SEO.astro';
import Scripts from '../components/Scripts.astro';
import EditAndFeedback from '../components/EditAndFeedback.astro';
import { ContentContainer } from '../components/ContentContainer';
import { MarketingFooter } from '../components/Footer/MarketingFooter';
import { MarketingHeader } from '../components/Header/MarketingHeader';
import { LayoutGrid } from '../components/LayoutGrid';
import Navigation from '../components/Navigation/Navigation.astro';
import { projectRoot } from '../util';
import CopyMarkdown from '../components/CopyMarkdown.astro';
import OnThisPage from '../components/OnThisPage.astro';
import SearchMeta from '../components/SearchMeta.astro';
import { globalStyles } from '../styles/global';
import {
  navGroups,
  flattenedNavItems,
} from '../components/Navigation/nav-groups';

type Props = {
  title: string;
  description: string;
  id: string;
  file?: string;
  headings: MarkdownHeading[];
  searchMetaType?: 'faq' | 'default' | 'hidden';
};

const { title, description, id, searchMetaType } = Astro.props;
const { pathname } = Astro.url;

const editUrl = Astro.props.file?.replace(projectRoot, '').replace('src/', '');
const rawMarkdownUrl = editUrl
  ? `https://raw.githubusercontent.com/chromaui/chromatic-docs/main/src/${editUrl}`
  : '';
const hasHeadings = Astro.props.headings.length > 0;
---

<html lang="en">
  <head>
    <SEO title={title} description={description} />
    <link rel="sitemap" href="/docs/sitemap-index.xml" />
    <style is:global set:html={globalStyles}></style>
    <Scripts />
    <style is:global>
      /* Copy Markdown — inline button */
      /* Mobile (< 768px, NavDropdownMenu visible): block row above H1 */
      .copy-md-inline {
        display: flex;
        justify-content: flex-start;
        margin-bottom: 2.5rem;
      }
      /* Tablet+ (≥ 768px): float right so it sits beside the H1 */
      @media (min-width: 768px) {
        .copy-md-inline {
          display: block;
          float: right;
          margin-left: 1rem;
          margin-bottom: 0;
        }
      }
      /* Hide when the OnThisPage sidebar is visible (≥ 1200px with ToC) */
      .has-toc .copy-md-inline {
        display: none;
      }
      /* Restore on mobile/tablet even with ToC (sidebar not shown there) */
      @media (max-width: 1199px) {
        .has-toc .copy-md-inline {
          display: flex;
        }
      }
      @media (min-width: 768px) and (max-width: 1199px) {
        .has-toc .copy-md-inline {
          display: block;
          float: right;
        }
      }
    </style>
  </head>
  <body class={hasHeadings ? 'has-toc' : ''}>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-K35MZQHR"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <MarketingHeader client:visible />
    <FullWidthContainer>
      <LayoutGrid showOnThisPage={hasHeadings}>
        <Navigation
          url={pathname.replace(/\/$/g, '')}
          navGroups={navGroups}
          flatNavItems={flattenedNavItems}
        />
        <ContentContainer>
          <SearchMeta
            id={id}
            flattenedNavItems={flattenedNavItems}
            type={searchMetaType}
          />
          {
            rawMarkdownUrl && (
              <div class="copy-md-inline">
                <CopyMarkdown rawMarkdownUrl={rawMarkdownUrl} />
              </div>
            )
          }
          <slot />
          <EditAndFeedback title={title} editUrl={editUrl} />
        </ContentContainer>
        {
          hasHeadings && (
            <OnThisPage
              headings={Astro.props.headings}
              rawMarkdownUrl={rawMarkdownUrl}
            />
          )
        }
      </LayoutGrid>
    </FullWidthContainer>
    <MarketingFooter />
    <script
      type="text/javascript"
      id="hs-script-loader"
      async
      defer
      src="//js.hs-scripts.com/45602133.js"></script>
    <script is:inline>
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-copy-md]');
        if (!btn) return;
        var url = btn.getAttribute('data-copy-md');
        fetch(url)
          .then(function (r) {
            return r.text();
          })
          .then(function (text) {
            navigator.clipboard.writeText(text).then(function () {
              btn.setAttribute('data-copied', '');
              setTimeout(function () {
                btn.removeAttribute('data-copied');
              }, 2000);
            });
          })
          .catch(function (err) {
            console.error('Failed to copy markdown:', err);
          });
      });
    </script>
  </body>
</html>
