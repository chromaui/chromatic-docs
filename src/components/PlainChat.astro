---
import {
  CHROMATIC_PLAIN_APP_ID,
  CHROMATIC_PLAIN_AUTH_ENDPOINT,
  PLAIN_LABEL_IDS,
} from './plainConfig';
---

<script is:inline src="https://chat.cdn-plain.com/index.js" async></script>
<script
  is:inline
  define:vars={{
    appId: CHROMATIC_PLAIN_APP_ID,
    authEndpoint: CHROMATIC_PLAIN_AUTH_ENDPOINT,
    labelIds: PLAIN_LABEL_IDS,
  }}
>
  // Keep in sync with monorepo services/webapp/lib/plainAuth.ts PLAIN_CONFIG
  // and marketing's equivalent so the widget looks identical across surfaces.
  const PLAIN_PAGE_EVENT_ENDPOINT = '/plain-page-event';
  const BASE_CONFIG = {
    appId: appId,
    hideBranding: true,
    theme: 'light',
    style: {
      brandColor: '#006deb',
      brandBackgroundColor: '#FFFFFF',
      launcherBackgroundColor: '#006deb',
      launcherIconColor: '#FFFFFF',
    },
    links: [
      {
        text: 'How does Chromatic work?',
        url: 'https://www.chromatic.com/docs/quickstart/',
        icon: 'book',
      },
      {
        text: 'Estimate snapshot usage',
        url: 'https://www.chromatic.com/snapshot-calculator',
        icon: 'bulb',
      },
      {
        text: 'Book a demo',
        url: 'https://www.chromatic.com/book-demo?type=opt3',
        icon: 'pencil',
      },
    ],
    position: { bottom: '20px', right: '20px' },
    chatButtons: [
      {
        icon: 'support',
        text: 'Chat with a developer',
      },
      {
        icon: 'chat',
        text: 'Speak with someone else',
        form: {
          fields: [
            {
              type: 'dropdown',
              placeholder: 'Select a topic...',
              options: [
                {
                  icon: 'chat',
                  text: 'Billing',
                  threadDetails: {
                    labelTypeIds: [labelIds.billing],
                  },
                },
                {
                  icon: 'chat',
                  text: 'Sales',
                  threadDetails: {
                    labelTypeIds: [labelIds.sales],
                  },
                },
              ],
            },
          ],
        },
      },
    ],
  };

  function reportPlainEvent(eventType, title) {
    fetch(PLAIN_PAGE_EVENT_ENDPOINT, {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        eventType,
        pathname: window.location.pathname,
        title,
        url: window.location.href,
        source: 'docs',
      }),
    }).catch(() => {
      // Best-effort support context only.
    });
  }

  (async function init() {
    for (let attempts = 0; typeof window.Plain === 'undefined' && attempts < 50; attempts++) {
      await new Promise((r) => setTimeout(r, 200));
    }
    if (typeof window.Plain === 'undefined') {
      console.warn('[plain] SDK did not load within 10s');
      return;
    }

    try {
      const response = await fetch(authEndpoint, {
        method: 'GET',
        credentials: 'include',
      });
      if (response.ok) {
        const customerDetails = await response.json();
        window.Plain.init({ ...BASE_CONFIG, customerDetails });
        reportPlainEvent('page-view', document.title);
        if (typeof window.Plain.onOpen === 'function') {
          window.Plain.onOpen(() => reportPlainEvent('chat-open', 'Started chat'));
        }
        return;
      }
      if (response.status !== 401) {
        console.warn(
          `[plain] Failed to fetch customer details: ${response.status} ${response.statusText}`
        );
      }
    } catch (error) {
      console.warn('[plain] Failed to fetch customer details', error);
    }

    window.Plain.init({ ...BASE_CONFIG, requireAuthentication: true });
  })();
</script>
